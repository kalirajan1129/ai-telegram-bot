# ─────────────────────────────────────────────
# ICT Signals Bot — Environment Config
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── Telegram ──────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=8243378949:AAHf4CxLSeddyXAEj3utEsuG0ibPA1YEX4k

# Your channel/group chat ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=your_chat_id_here

# Comma-separated admin user IDs
# TELEGRAM_ADMIN_IDS=[123456789]

# ── Twelve Data API (Forex Feed) ──────────────
# Free signup at https://twelvedata.com
# Free tier: 800 requests/day, 8/min — enough for Forex polling
# Leave empty to use anonymous free tier (same limits, no key needed for basic use)
TWELVE_DATA_API_KEY=

# ── Signal Settings ───────────────────────────
# Minimum ML confidence % to send a signal
MIN_CONFIDENCE=60.0

# How many timeframes must agree (out of 3: 5m/15m/1h)
MIN_AGREEING_TIMEFRAMES=2

# Max signals per pair per hour (anti-spam)
MAX_SIGNALS_PER_HOUR=10

# ── Forex Feed Timing ─────────────────────────
# How often to poll latest price (seconds) — min 8s for free Twelve Data tier
FOREX_POLL_INTERVAL=10

# How often to refresh full OHLCV candles (seconds)
FOREX_CANDLE_REFRESH=300

# ── ML Settings ───────────────────────────────
RETRAIN_INTERVAL_HOURS=6
MIN_SAMPLES_FOR_TRAINING=500

# ── Risk Filters ──────────────────────────────
ADX_MIN_TREND=20.0
VOLATILITY_MIN=0.0003
VOLATILITY_MAX=0.08

# ── App ───────────────────────────────────────
DEBUG=False
LOG_LEVEL=INFO
